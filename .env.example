# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# ─── Cron (SCH-23 tier-timer sweep) ──────────────────────────────────────────
# Shared secret; Vercel Cron sends it as `Authorization: Bearer $CRON_SECRET`
# to /api/cron/coverage-tiers. Set the same value in the Vercel project env.
CRON_SECRET=

# ─── Twilio SMS (Milestone 4 — SCH-26) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 format, e.g. +16045551234
TWILIO_PHONE_NUMBER=
# SMS is sent ONLY when this is exactly "true" AND the three vars above are set.
# Leave unset in dev/CI so no real texts are ever sent; use Twilio TEST creds in
# staging. Requires A2P 10DLC registration before production (see docs/twilio-a2p.md).
SMS_LIVE=
# Optional: the exact public URL Twilio calls for inbound replies. If set, the
# inbound webhook validates signatures against it instead of reconstructing from
# request headers (used by the E2E suite; recommended in prod behind a proxy).
TWILIO_INBOUND_URL=

# ─── Resend email (Milestone 4 — SCH-25) ─────────────────────────────────────
RESEND_API_KEY=
# Verified sender address, e.g. shifts@yourbusiness.com (display name from settings)
RESEND_FROM=

# ─── Sentry (added in Milestone 5 — SCH-27) ──────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
